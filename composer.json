{
  "name": "eduardokum/laravel-boleto",
  "description": "Biblioteca com boletos para o laravel",
  "keywords": [
    "eduardokum",
    "laravel-boleto"
  ],
  "homepage": "https://github.com/eduardokum/laravel-boleto",
  "license": "MIT",
  "authors": [
    {
      "name": "Eduardo Gusmão",
      "email": "eduguscontra3@hotmail.com"
    }
  ],
  "require": {
    "php": "^7.2|^8.0",
    "ext-intl": "*",
    "ext-mbstring": "*",
    "laravel/framework": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
    "neitanod/forceutf8": "^2.0",
    "setasign/fpdf": "^1.8",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-openssl": "*",
    "chillerlan/php-qrcode": "^3.0|^4.0|^5.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0",
    "orchestra/testbench": "^4.0|^5.0|^6.0|^7.0|^8.0|^9.0|^10.0|^11.0",
    "friendsofphp/php-cs-fixer": "*"
  },
  "suggest": {
    "eduardokum/laravel-mail-auto-embed": "Ativa embed automático de imagens em templates de e-mail."
  },
  "autoload": {
    "psr-4": {
      "Eduardokum\\LaravelBoleto\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Eduardokum\\LaravelBoleto\\Tests\\": "tests"
    }
  },
  "config": {
    "allow-plugins": true
  },
  "scripts": {
    "php-cs-fixer-check": "vendor/bin/php-cs-fixer fix --diff --verbose --dry-run",
    "php-cs-fixer": "vendor/bin/php-cs-fixer fix --verbose"
  }
}
